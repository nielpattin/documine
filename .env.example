# Optional overrides for npm run dev.
# Leave this file copied to .env only when you need to avoid local port conflicts.

# API dev server. Defaults to 3120 when unset.
# PORT=3121

# Web dev server. Defaults to 5175 when unset.
# DOCUMINE_WEB_PORT=5176

# Usually not needed. When PORT is set, npm run dev automatically points the web app at that API port.
# Use these only if the browser must reach the API through a different origin.
# VITE_DOCUMINE_API_HTTP_ORIGIN=http://localhost:3121
# VITE_DOCUMINE_API_WS_ORIGIN=ws://localhost:3121
